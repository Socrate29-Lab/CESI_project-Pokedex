<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.pokedex.PokedexController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="loadText"/>
    <Button text="Charger les données depuis mariaDB" onAction="#onLoadDBButtonClick"/>
    <TableView fx:id="pokedex">
        <columns>
            <TableColumn fx:id="colNom" text="Nom"/>
            <TableColumn fx:id="colNiveau" text="Niveau"/>
            <TableColumn fx:id="colPdV" text="Points de vie"/>
            <TableColumn fx:id="colXp" text ="Expérience"/>
            <TableColumn fx:id="colType" text="Type" />
        </columns>
    </TableView>
</VBox>
